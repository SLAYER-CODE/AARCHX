<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0D1F0D"
    android:clickable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/layout_for_dco"
        android:layout_margin="8dp">

        <include
            android:id="@+id/header"
            layout="@layout/item_tool_header"
            android:layout_alignParentTop="true"/>

        <FrameLayout
            android:id="@+id/scroll_indicator"
            android:layout_below="@id/header"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#001100">

            <View
                android:id="@+id/scroll_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#08ff00" />
        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tool_list"
            android:layout_below="@id/scroll_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"/>

    </RelativeLayout>
</FrameLayout>