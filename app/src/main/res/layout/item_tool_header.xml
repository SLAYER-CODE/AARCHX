<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="40dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/banner"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:scaleType="fitXY"/>

    <TextView
        android:id="@+id/title"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/whitefull"
        android:gravity="start|center_vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:fontFamily="sans-serif-condensed-medium"/>

    <TextView
        android:id="@+id/stats_compact"
        android:text="H:0 D:0 A:-"
        android:textSize="9sp"
        android:textColor="@color/cyan_bright"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginEnd="4dp"/>

    <TextView
        android:id="@+id/stats_size"
        android:text="0mb"
        android:textSize="11sp"
        android:textColor="@color/orange_yellow"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"/>

    <TextView
        android:id="@+id/stats_tools"
        android:text="0"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>

    <TextView
        android:id="@+id/stats_downloaded"
        android:text="0"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>

    <TextView
        android:id="@+id/stats_updated"
        android:text="-"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>

</androidx.appcompat.widget.LinearLayoutCompat>
