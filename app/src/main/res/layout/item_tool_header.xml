<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:gravity="center_vertical">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/banner"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitXY"
        android:layout_centerVertical="true"
        android:layout_marginStart="4dp"/>

    <TextView
        android:id="@+id/stats_size"
        android:text="0mb"
        android:textSize="14sp"
        android:textColor="@color/orange_yellow"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="60dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="6dp"/>

    <LinearLayout
        android:id="@+id/stats_wrapper"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_toEndOf="@+id/sep1"
        android:layout_toStartOf="@+id/stats_size"
        android:layout_marginEnd="4dp"
        android:gravity="center_vertical">
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:text="Herramientas: " android:textSize="7sp" android:textColor="@color/neon_green" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/stats_tools" android:text="0" android:textSize="7sp" android:textColor="@color/cyan_bright" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:text="Descargadas: " android:textSize="7sp" android:textColor="@color/neon_green" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/stats_downloaded" android:text="0" android:textSize="7sp" android:textColor="@color/light_green" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:text="Actualizada: " android:textSize="7sp" android:textColor="@color/neon_green" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/stats_updated" android:text="-" android:textSize="7sp" android:textColor="@color/orange_bright" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/sep1"
        android:text="|"
        android:textSize="11sp"
        android:textColor="@color/divider_green"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="3dp"
        android:layout_toEndOf="@+id/title"
        android:layout_toStartOf="@+id/stats_wrapper"
        android:layout_centerVertical="true"/>

    <TextView
        android:id="@+id/title"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/whitefull"
        android:gravity="start|center_vertical"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_toEndOf="@+id/banner"
        android:layout_toStartOf="@+id/sep1"
        android:layout_marginStart="4dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-condensed-medium"/>

</RelativeLayout>