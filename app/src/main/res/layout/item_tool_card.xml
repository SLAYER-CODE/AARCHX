<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:theme="@style/Theme.AppCompat"
    android:layout_gravity="center"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    app:cardBackgroundColor="#000000"
    app:cardCornerRadius="2dp"
    app:contentPadding="0dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp">
        <View
            android:id="@+id/status_bar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:background="#006400" />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="fitXY"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@+id/status_bar"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/tool_title_gray"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="4dp"
            android:layout_toStartOf="@+id/install_btn"
            android:layout_toEndOf="@+id/icon"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="sans-serif-condensed-medium"/>
        <TextView
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/tool_desc_gray"
            android:id="@+id/description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title"
            android:layout_toStartOf="@+id/install_btn"
            android:layout_toEndOf="@+id/icon"
            android:maxLines="2"
            android:ellipsize="end"/>
        <LinearLayout
            android:id="@+id/badge_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/description"
            android:layout_toStartOf="@+id/install_btn"
            android:layout_toEndOf="@+id/icon"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">
            <TextView
                android:id="@+id/badge_size"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#00FF00"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="20dp" />
            <TextView
                android:id="@+id/uninstall_badge"
                android:text="UNINSTALL"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FF4444"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:id="@+id/install_btn"
            android:src="@drawable/ic_install"
            android:tint="#006400" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>
