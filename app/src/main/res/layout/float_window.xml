<?xml version="1.0" encoding="utf-8"?>
<org.aarchdroid.dragonterminal.floatui.FloatWindowView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/float_window_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.aarchdroid.dragonterminal.frontend.terminal.TerminalView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:minHeight="50dp" />

    <LinearLayout
        android:id="@+id/window_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="2dp">

        <ImageButton
            android:id="@+id/resize_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_float_resize"
            android:contentDescription="@string/float_resize"
            android:scaleType="center" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/minimize_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_minimize"
            android:contentDescription="@string/float_minimize"
            android:layout_marginEnd="4dp"
            android:scaleType="center" />

        <ImageButton
            android:id="@+id/keyboard_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_keyboard_black_24dp"
            android:contentDescription="@string/toggle_ime"
            android:layout_marginEnd="4dp"
            android:scaleType="center" />

        <ImageButton
            android:id="@+id/exit_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@null"
            android:src="@drawable/ic_float_close"
            android:contentDescription="@string/float_exit"
            android:scaleType="center" />

    </LinearLayout>

</org.aarchdroid.dragonterminal.floatui.FloatWindowView>
