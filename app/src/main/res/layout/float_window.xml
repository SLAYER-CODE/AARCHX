<?xml version="1.0" encoding="utf-8"?>
<org.aarchdroid.dragonterminal.floatui.FloatWindowView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/float_window_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <org.aarchdroid.dragonterminal.frontend.terminal.TerminalView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:minHeight="50dp" />

    <LinearLayout
        android:id="@+id/window_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="2dp"
        android:background="#FF0A2809">

        <TextView
            android:id="@+id/resize_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="+"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/float_resize" />

        <TextView
            android:id="@+id/anchor_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="↓"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/float_anchor" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/minimize_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="-"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/float_minimize" />

        <TextView
            android:id="@+id/keyboard_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="@"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/toggle_ime" />

        <TextView
            android:id="@+id/exit_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="X"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/float_exit" />

    </LinearLayout>

</org.aarchdroid.dragonterminal.floatui.FloatWindowView>
