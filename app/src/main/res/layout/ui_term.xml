<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.aarchdroid.dragonterminal.frontend.terminal.TerminalView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/extra_keys"
        android:background="@color/terminal_background"
        android:fadeScrollbars="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:scrollbars="vertical" />

    <org.aarchdroid.dragonterminal.frontend.terminal.extrakey.ExtraKeysView
        android:id="@+id/extra_keys"
        style="?android:buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/terminal_background"
        android:orientation="horizontal" />

    <ImageButton
        android:id="@+id/float_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/round_button_with_outline"
        android:contentDescription="@string/float_up"
        android:src="@drawable/ic_float"
        android:visibility="gone"
        android:scaleType="center"
        android:padding="4dp" />

</RelativeLayout>
