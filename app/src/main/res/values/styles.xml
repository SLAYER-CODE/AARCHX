<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="alertDialogTheme">@style/AppCompatAlertDialogStyle</item>
        <item name="android:colorBackground">@color/background_material_dark</item>
        <item name="android:windowFullscreen">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="android:actionBarSize">45dp</item>

    </style>

    <style name="AppThemeTerminal" parent="Theme.AppCompat">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowContentOverlay">@null</item>
        <!-- Main theme colors -->
        <!--   your app branding color for the app bar -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="alertDialogTheme">@style/AppCompatAlertDialogStyle</item>
        <item name="android:colorBackground">@color/background_material_dark</item>


    </style>

    <style name="AppCompatAlertDialogStyle" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:textColor">#000000</item>
        <item name="android:background">#FFFFFF</item>
        <item name="colorAccent">#eb0000</item>
    </style>

    <style name="AppCompatCrashDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:colorBackground">#000000</item>

        <item name="android:background">#000000</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light">

    </style>

    <style name="AppTheme.PopupOverlay.GreenBorder" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:actionOverflowMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
        <item name="popupMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
    </style>

    <style name="Widget.GreenBorder.PopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_menu_green_border</item>
    </style>

    <style name="Theme.CompactGreenPopup" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:listPreferredItemHeightSmall">36dp</item>
        <item name="android:dropDownListViewStyle">@style/Widget.CompactDropDownList</item>
    </style>

    <style name="Widget.CompactDropDownList" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:scrollbarTrackVertical">@drawable/scrollbar_track_vertical</item>
        <item name="android:scrollbarThumbVertical">@drawable/scrollbar_thumb_vertical</item>
        <item name="android:scrollbarStyle">insideOverlay</item>
        <item name="android:scrollbarAlwaysDrawVerticalTrack">true</item>
    </style>

    <style name="AppTheme.DcoDialog" parent="Theme.AppCompat.Dialog">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    
    <style name="AppTheme.Dark" parent="Theme.AppCompat">
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="colorPrimary">@color/blackfull</item>
        <item name="colorPrimaryDark">@color/blackfull</item>
    </style>

    <style name="AppTheme.BlackFull" parent="Theme.AppCompat">
        <item name="alertDialogTheme">@style/AppCompatAlertDialogStyle</item>
        <item name="alertDialogStyle">@style/AppCompatAlertDialogStyle</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="android:colorBackground">@color/background_material_dark</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
    </style>

    <style name="AppTheme.NoActionBar.Dark" parent="@style/AppTheme.Dark">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.NoActionBar.Dark2" parent="@style/AppTheme.BlackFull">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:actionOverflowMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.GreenBorder.PopupMenu</item>
        <item name="android:actionOverflowButtonStyle">@style/Widget.GearOverflow</item>
        <item name="actionOverflowButtonStyle">@style/Widget.GearOverflow</item>
    </style>

    <style name="Widget.GearOverflow" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:src">@drawable/ic_gear</item>
        <item name="srcCompat">@drawable/ic_gear</item>
    </style>

    <style name="rtl_RecyclerTabLayout">
        <item name="rtl_tabMinWidth">72dp</item>
        <item name="rtl_tabMaxWidth">264dp</item>
        <item name="rtl_tabIndicatorColor">?attr/colorAccent</item>
        <item name="rtl_tabIndicatorHeight">2dp</item>
        <item name="rtl_tabPaddingStart">12dp</item>
        <item name="rtl_tabPaddingEnd">12dp</item>
        <item name="rtl_tabBackground">?attr/selectableItemBackground</item>
        <item name="rtl_tabTextAppearance">@style/rtl_RecyclerTabLayout.Tab</item>
        <item name="rtl_tabSelectedTextColor">?android:textColorPrimary</item>
    </style>

    <style name="rtl_RecyclerTabLayout.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="textAllCaps">true</item>
    </style>


</resources>
